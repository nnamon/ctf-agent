# Thin sidecar image for HtbMachinesBackend's VPN tunnel.
# Solver containers attach via `--network container:<this>` and route
# their traffic through tun0 to reach 10.10.x.x HTB targets. Solver
# containers themselves don't need openvpn — only this sidecar does.
#
# Alpine base because we want this small (~12 MB compressed). The only
# requirements are openvpn itself and iproute2 for the readiness probe
# (`ip addr show tun0` to confirm the tunnel came up).

FROM alpine:3.20

RUN apk add --no-cache \
    openvpn \
    iproute2 \
    ca-certificates

# openvpn drops privileges by default which is fine for a sidecar; the
# CMD is set by the caller (HtbMachinesBackend passes the full openvpn
# invocation including --config /vpn.ovpn).
ENTRYPOINT []
CMD ["openvpn", "--version"]
