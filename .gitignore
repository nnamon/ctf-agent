# Credentials
.env
creds.json

# Logs and traces
logs/
*.log
*.jsonl

# Challenges fetched at runtime (CTFd pull) are excluded by default.
challenges_*/
challenges/*/
challenges/*/distfiles/

# Toy / demo challenges are checked in as a self-hosted CTFd test
# instance (see toy-challenges/README.md). Distfiles of binary-producing
# challenges are still excluded — `./build.sh` regenerates them. The
# pure-data ones (e.g. toy-xor-b64/distfiles/cipher.txt) ARE tracked.
toy-challenges/*/distfiles/
!toy-challenges/toy-xor-b64/distfiles/

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
.mypy_cache/
.ruff_cache/
uv.lock

# Runtime
workspace/
codex-schema-*/
.claude/scheduled_tasks.lock
