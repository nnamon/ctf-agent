# Credentials
.env
creds.json

# Logs and traces
logs/
*.log
*.jsonl

# Challenges fetched at runtime (CTFd pull) are excluded by default.
# Test-benchmark challenges are whitelisted below; their distfiles are
# still excluded since `./build.sh` regenerates them.
challenges_*/
challenges/*/
!challenges/web-vault/
!challenges/pwn-echo/
!challenges/jvm-deser/
challenges/*/distfiles/

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/
.mypy_cache/
.ruff_cache/
uv.lock

# Runtime
workspace/
codex-schema-*/
.claude/scheduled_tasks.lock
